# awase 設定ファイル
#
# このファイルを config.toml にコピーして使用してください。
# cp config.toml.sample config.toml

[general]
# キーボードの物理レイアウト（"jis" or "us"）
#
# "us" にする場合、無変換/変換キー前提の left_thumb_key/right_thumb_key と
# default_layout を必ず一緒に変更すること（下記 US 配列の例を参照）。
# 変更を忘れると起動時に警告が出る（AppConfig::validate）。
keyboard_model = "jis"

# 同時打鍵の判定閾値（ミリ秒、NICOLA 規格標準: 100ms）
simultaneous_threshold_ms = 100

# 左親指キー / 右親指キー
left_thumb_key = "Nonconvert"
right_thumb_key = "Convert"

# US 配列の場合の設定例（無変換/変換キーが物理的に存在しないため）:
#
# 注意: VK_LMENU/VK_RMENU（Alt）・VK_LCONTROL/VK_RCONTROL（Ctrl）・VK_LWIN/VK_RWIN
# （Win）は親指キーに使えません。これらは OS 予約修飾キーとして扱われ、
# そのキーの KeyDown 自体が即座に OS へ素通しされてしまい、同時打鍵検出（親指シフト
# の根幹）が一切機能しません（engine/tests.rs の
# test_ctrl_alt_win_thumb_key_never_enters_pending_due_to_os_modifier_bypass で確認済み）。
# 「特定の物理 Alt キーだけ親指シフト専用にし、Alt としての機能は別キーに逃がす」
# という運用を本当にサポートするには、左右の Alt を別々に追跡する設計変更が
# 必要ですが未実装です。
#
# 現実的な選択肢:
#   (a) プログラマブルキーボード（QMK/ZMK 等）で予備キーを無変換/変換や
#       F13-F24 に物理リマップし、下記の親指キー設定は変えずに使う
#   (b) VK_SPACE を親指キーにする（単独タップ時に空白が誤挿入され得るが、
#       Alt のようなシステムレベルの副作用は無い）
#
#   keyboard_model = "us"
#   left_thumb_key = "VK_SPACE"     # (b) の例。(a) が使えるならそちらを推奨
#   right_thumb_key = "VK_F13"      # プログラマブルキーボード側で物理キーに割当て
#   default_layout = "nicola_us.yab"
#   [keys]
#   engine_on = ["Ctrl+Shift+VK_F14"]
#   engine_off = ["Ctrl+Shift+VK_F15"]
#   ime_on = ["Ctrl+VK_F14"]
#   ime_off = ["Ctrl+VK_F15"]

# 配列定義ファイル
layouts_dir = "layout"
default_layout = "nicola.yab"   # US 配列では "nicola_us.yab" を指定

# 確定モード
#   wait             - タイムアウトまで出力を保留
#   speculative      - 即座に出力、同時打鍵時に BS で差し替え
#   two_phase        - 短い待機→投機出力→差し替え
#   adaptive_timing  - 連続中は待機、途切れたら投機
#   ngram_predictive - n-gram 予測で投機/待機を動的切替
confirm_mode = "ngram_predictive"
# speculative_delay_ms = 30

# ローマ字出力の送信方式
#   per_key  - 1文字ずつ個別にキーイベントを送信
#   batched  - 全文字を1回にまとめて送信
#   unicode  - ひらがなに変換して Unicode 文字として直接送信
output_mode = "unicode"

# フックの動作モード
#   filter - PassThrough キーは OS にそのまま通す（低レイテンシ）
#   relay  - 全キーを Consume し、メッセージループで再注入（キー順序保証）
hook_mode = "relay"

# n-gram コーパスファイル（.csv.gz / .toml 対応）
ngram_file = "data/ngram_hiragana.csv.gz"
# ngram_adjustment_range_ms = 20
# ngram_min_threshold_ms = 30
# ngram_max_threshold_ms = 120

# エンジン ON/OFF トグルホットキー
engine_toggle_hotkey = "Ctrl+Shift+F12"

# フォーカス遷移デバウンス時間（ミリ秒）
# focus_debounce_ms = 50

# IME 状態ポーリング間隔（ミリ秒）
# ime_poll_interval_ms = 500

# Linux 入力バックエンド（Linux のみ有効）
# linux_input_backend = "evdev"
# linux_evdev_device = "/dev/input/event0"

# キーバインディング設定
[keys]
# エンジン ON/OFF キー（複数指定可）
engine_on = ["Ctrl+Shift+Convert"]
engine_off = ["Ctrl+Shift+Nonconvert"]

# IME ON/OFF キー（複数指定可）
ime_on = ["Ctrl+Convert"]
ime_off = ["Ctrl+Nonconvert"]

# IME 検出設定（シャドウ IME 状態追跡用キー定義）
[keys.ime_detect]
toggle = ["VK_KANJI"]
on = ["VK_DBE_DBCSCHAR", "VK_IME_ON"]
off = ["VK_DBE_SBCSCHAR", "VK_IME_OFF"]

# フォーカス判定のオーバーライド
# [focus_overrides]
# force_text = [
#     { process = "browser", class = "WebContent" },
# ]
# force_bypass = [
#     { process = "launcher", class = "SearchBox" },
# ]
# # ローマ字出力を VK キーストロークで送る (IME composition 必須のアプリ用)
# force_vk = [
#     { process = "wezterm-gui.exe", class = "org.wezfurlong.wezterm" },
# ]
