        },
        Response {
            actions: vec![KeyAction::Char('し')],
            consumed: true,
            timers: vec![],
        },
    ];
    let chars = collect_chars(&responses);
    assert_eq!(chars, vec!['う', 'し'], "No BS means all chars preserved");
}

