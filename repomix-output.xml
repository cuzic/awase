    let r = engine.on_event(Ev::up(VK_D).build());
    r.assert_consumed();
    assert!(r
        .actions
        .iter()
        .any(|a| matches!(a, KeyAction::Key(x) if *x == VK_D)));
    assert!(r
        .actions
        .iter()
        .any(|a| matches!(a, KeyAction::KeyUp(x) if *x == VK_D)));
}

