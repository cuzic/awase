#[test]
fn test_bypass_state_repr_values() {
    // repr(u8) の値が AtomicU8 との変換で正しいことを確認
    assert_eq!(FocusKind::TextInput as u8, 0);
    assert_eq!(FocusKind::NonText as u8, 1);
